function iniciarAnimacaoBoca(texto, token, opcoes = {}) {
  const frames = opcoes.frames || FRAMES_RESPOSTA;
  const framesCarregados = frames.filter((frame) => mascoteFramesCarregados.has(frame));
  if (framesCarregados.length < 8) {
    setTimeout(() => {
      if (token !== falaTokenAtual) return;
      iniciarAnimacaoBoca(texto, token, opcoes);
    }, 120);
    return;
  }
  const intervaloBase = Number.isFinite(opcoes.intervaloMs) ? opcoes.intervaloMs : 120;
  let curr = 0;
  if (bocaAnimacaoId) {
    cancelAnimationFrame(bocaAnimacaoId);
  }
  let ultimo = performance.now();
  const intervalo = Math.max(60, intervaloBase);
  const avancar = (agora) => {
    if (token !== falaTokenAtual) return;
    if (agora - ultimo >= intervalo) {
      setMascotPose(framesCarregados[curr]);
      curr = (curr + 1) % framesCarregados.length;
      ultimo = agora;
    }
    bocaAnimacaoId = requestAnimationFrame(avancar);
  };
  bocaAnimacaoId = requestAnimationFrame(avancar);
}

function pararAnimacaoFala(poseFinal = POSE_ESPERA) {
  clearTimeout(talkTimeout);
  talkTimeout = null;
  if (bocaAnimacaoId) {
    cancelAnimationFrame(bocaAnimacaoId);
    bocaAnimacaoId = null;
  }
  setMascotPose(poseFinal);
}

function selecionarVozPolia() {
  if (USAR_VOZ_PADRAO_DO_SISTEMA) {
    vozPolia = null;
    return;
  }

  const vozes = window.speechSynthesis.getVoices();
  if (!vozes.length) {
    vozPolia = null;
    return;
  }

  const ptBR = vozes.filter(v => {
    const lang = (v.lang || '').toLowerCase().replace('_', '-');
    const nome = (v.name || '').toLowerCase();
    return lang.startsWith('pt-br') || nome.includes('brazil');
  });

  if (!ptBR.length) {
    vozPolia = null;
    return;
  }

  const nomesFemininos = ['luciana', 'camila', 'joana', 'fernanda', 'vitoria', 'vitória', 'marisa', 'julia', 'júlia', 'marina', 'barbara', 'bárbara'];
  const preferidas = [VOZ_PREFERIDA, ...VOZ_ALTERNATIVAS].map(v => v.toLowerCase());

  vozPolia =
    ptBR.find(v => preferidas.some(p => (v.name || '').toLowerCase().includes(p))) ||
    ptBR.find(v => nomesFemininos.some(n => (v.name || '').toLowerCase().includes(n))) ||
    ptBR.find(v => v.default) ||
    ptBR[0];
}

function desenharTrilhasFixas() {
  trilhasSvg.innerHTML = '';
  const pares = new Set();

  Object.entries(conexoes).forEach(([origem, vizinhos]) => {
    vizinhos.forEach(destino => {
      const chave = [origem, destino].sort().join('|');
      if (pares.has(chave) || !locaisCache[origem] || !locaisCache[destino]) return;
      
      const p1 = percentualParaPixel(locaisCache[origem].x, locaisCache[origem].y);
      const p2 = percentualParaPixel(locaisCache[destino].x, locaisCache[destino].y);
      
      const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.setAttribute('d', `M ${p1.x} ${p1.y} L ${p2.x} ${p2.y}`);
      path.setAttribute('class', 'linha-trilha');
      trilhasSvg.appendChild(path);

      pares.add(chave);
    });
  });
}

function encontrarRota(origem, destino) {
  if (origem === destino) return [origem];
  const fila = [[origem]], visitados = new Set([origem]);
  while (fila.length > 0) {
    const caminho = fila.shift(), ultimo = caminho[caminho.length - 1];
    for (const v of (conexoes[ultimo] || [])) {
      if (visitados.has(v)) continue;
      const novo = [...caminho, v];
      if (v === destino) return novo;
      visitados.add(v); fila.push(novo);
    }
  }
  return null;
}

async function animarAvatarNaRota(rota, tokenMovimento) {
