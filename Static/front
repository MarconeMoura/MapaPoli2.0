}

function configurarFalaAnimada(texto, poseFinal = POSE_ESPERA, opcoes = {}) {
  const usarAnimacaoApresentacao = Boolean(opcoes.apresentacao);
  const poseFinalLocal = POSE_APRESENTACAO_FIM;
  const animacao = opcoes.animacao || null;
  const onEnd = typeof opcoes.onEnd === 'function' ? opcoes.onEnd : null;
  const bocaIntervalo = Number.isFinite(animacao?.boca?.intervalo_ms) ? animacao.boca.intervalo_ms : null;
  const bocaFrames = Array.isArray(animacao?.boca?.sequencia) && animacao.boca.sequencia.length
    ? animacao.boca.sequencia
    : FRAMES_RESPOSTA;
  
  const ajustarSequenciaBoca = (frames, maxLen = 60) => {
    if (!Array.isArray(frames) || !frames.length) return FRAMES_RESPOSTA;
    if (frames.length <= maxLen) return frames;
    const passo = Math.ceil(frames.length / maxLen);
    return frames.filter((_, idx) => idx % passo === 0);
  };
  
  const bocaFramesAjustados = ajustarSequenciaBoca(bocaFrames);
  const estimarDuracaoTextoMs = (frase) => {
    const textoLimpo = (frase || '').trim();
    const palavras = Math.max(1, (textoLimpo.match(/\b\w+\b/g) || []).length);
    return Math.max(900, Math.floor(((palavras * 0.42) + (textoLimpo.length * 0.004)) * 1000));
  };
  
  falaTokenAtual += 1;
  const meuToken = falaTokenAtual;
  const textoFala = ajustarTextoFala(texto);

  window.speechSynthesis.cancel();
  clearTimeout(talkTimeout);
  clearTimeout(apresentacaoTimeout);
  apresentacaoTokenAtual += 1;

  if (usarAnimacaoApresentacao) {
    setMascotPose(FRAMES_APRESENTACAO[0] || POSE_APRESENTACAO_FIM || POSE_ESPERA);
  } else {
    setMascotPose(FRAME_PENSAR);
  }

  if (audioPoliaAtual) {
    audioPoliaAtual.pause();
    audioPoliaAtual = null;
  }
  if (audioPoliaUrlAtual) {
    URL.revokeObjectURL(audioPoliaUrlAtual);
    audioPoliaUrlAtual = null;
  }

  const fallbackNavegador = () => {
    if (USAR_TTS_API && FORCAR_TTS_API) {
      console.warn('TTS API falhou; fallback de voz desativado.');
      return;
    }
    if (!vozPolia) selecionarVozPolia();
    const f = new SpeechSynthesisUtterance(textoFala);
    f.lang = 'pt-BR';
    f.rate = VELOCIDADE_VOZ;
    f.pitch = PITCH_VOZ;
    if (vozPolia && !USAR_VOZ_PADRAO_DO_SISTEMA) {
      f.voice = vozPolia;
    }
    f.onstart = () => {
      if (meuToken !== falaTokenAtual) return;
      atualizarBalao(texto);
      if (usarAnimacaoApresentacao) {
        iniciarAnimacaoApresentacao(meuToken);
      } else {
        iniciarAnimacaoBoca(texto, meuToken, { intervaloMs: bocaIntervalo });
      }
    };
    f.onend = () => {
      if (meuToken !== falaTokenAtual) return;
      if (usarAnimacaoApresentacao) {
        pararAnimacaoApresentacao(poseFinalLocal);
      } else {
        pararAnimacaoFala(poseFinalLocal);
      }
      if (onEnd) onEnd();
    };
    window.speechSynthesis.speak(f);
  };

  if (!USAR_TTS_API) {
    fallbackNavegador();
    return;
  }

  if (usarAnimacaoApresentacao) {
    atualizarBalao(texto);
    setTimeout(() => {
      if (meuToken !== falaTokenAtual) return;
      iniciarAnimacaoApresentacao(meuToken, estimarDuracaoTextoMs(texto));
    }, AUDIO_START_DELAY_MS);
  }

  setTimeout(async () => {
    try {
      const res = await fetch('/api/tts', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({texto: textoFala})
      });

      const contentType = (res.headers.get('content-type') || '').toLowerCase();
      if (!res.ok || contentType.includes('application/json')) {
        fallbackNavegador();
        return;
      }

      const blob = await res.blob();
      if (!blob || !blob.size) {
        fallbackNavegador();
        return;
      }

      if (meuToken !== falaTokenAtual) return;

      atualizarBalao(texto);

      audioPoliaUrlAtual = URL.createObjectURL(blob);
      audioPoliaAtual = new Audio(audioPoliaUrlAtual);
      audioPoliaAtual.onplay = () => {
        if (meuToken !== falaTokenAtual) return;
        if (usarAnimacaoApresentacao) {
          iniciarAnimacaoApresentacao(meuToken, Number.isFinite(audioPoliaAtual.duration) ? audioPoliaAtual.duration * 1000 : null);
        } else {
          const duracaoMs = Number.isFinite(audioPoliaAtual.duration) ? audioPoliaAtual.duration * 1000 : null;
          const intervaloAudio = duracaoMs && bocaFramesAjustados.length
            ? Math.max(45, Math.floor(duracaoMs / bocaFramesAjustados.length))
            : null;
          iniciarAnimacaoBoca(texto, meuToken, { frames: bocaFramesAjustados, intervaloMs: intervaloAudio || bocaIntervalo });
        }
      };
      audioPoliaAtual.onended = () => {
        if (meuToken !== falaTokenAtual) return;
        if (usarAnimacaoApresentacao) {
          pararAnimacaoApresentacao(poseFinalLocal);
        } else {
          pararAnimacaoFala(poseFinalLocal);
        }
        if (audioPoliaUrlAtual) {
          URL.revokeObjectURL(audioPoliaUrlAtual);
          audioPoliaUrlAtual = null;
        }
        audioPoliaAtual = null;
        if (onEnd) onEnd();
      };
      audioPoliaAtual.onerror = () => {
        if (meuToken !== falaTokenAtual) return;
        if (usarAnimacaoApresentacao) {
          pararAnimacaoApresentacao(poseFinalLocal);
        } else {
          pararAnimacaoFala(poseFinalLocal);
        }
        if (audioPoliaUrlAtual) {
          URL.revokeObjectURL(audioPoliaUrlAtual);
          audioPoliaUrlAtual = null;
        }
        audioPoliaAtual = null;
        fallbackNavegador();
      };

      try {
        tentarTocarAudio(audioPoliaAtual);
        if (audioBloqueado) {
          prepararDesbloqueioAudio();
        }
      } catch (_) {
        if (meuToken !== falaTokenAtual) return;
        fallbackNavegador();
      }
    } catch (_) {
      if (meuToken !== falaTokenAtual) return;
      fallbackNavegador();
    }
  }, 100);
}

