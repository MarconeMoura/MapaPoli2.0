function aguardarFramesMascote(frames, minimo = 20, timeoutMs = 2000) {
  const lista = Array.isArray(frames) && frames.length ? frames : FRAMES_RESPOSTA;
  let carregados = 0;
  lista.forEach((frame) => {
    if (mascoteFramesCarregados.has(frame)) {
      carregados += 1;
      return;
    }
    const img = new Image();
    img.onload = () => mascoteFramesCarregados.add(frame);
    img.onerror = () => mascoteFramesCarregados.add(frame);
    img.src = `/static/${frame}`;
  });

  if (carregados >= minimo) return Promise.resolve(true);

  return new Promise((resolve) => {
    const inicio = Date.now();
    const timer = setInterval(() => {
      const total = lista.filter((f) => mascoteFramesCarregados.has(f)).length;
      if (total >= minimo || Date.now() - inicio > timeoutMs) {
        clearInterval(timer);
        resolve(total >= minimo);
      }
    }, 80);
  });
}

