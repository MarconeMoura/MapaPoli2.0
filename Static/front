function construirAliasesLocais() {
  const aliasMap = new Map();
  const adicionarAlias = (alias, id, minLen = 2) => {
    if (!alias || alias.length < minLen) return;
    const existentes = aliasMap.get(alias) || new Set();
    existentes.add(id);
    aliasMap.set(alias, existentes);
  };
  Object.keys(locaisCache).forEach((id) => {
    const idNorm = normalizarTexto(id);
    const opcoes = new Set([idNorm]);

    if (idNorm.startsWith('bloco ')) {
      const sufixo = idNorm.replace('bloco ', '').trim();
      opcoes.add(`bloco ${sufixo}`);
      if (sufixo === 'i/k') {
        opcoes.add('bloco i');
        opcoes.add('bloco k');
        opcoes.add('ik');
        opcoes.add('i k');
      }
    }

    if (idNorm === 'entrada') {
      opcoes.add('portao');
      opcoes.add('portao principal');
      opcoes.add('acesso principal');
      opcoes.add('inicio');
    }

    if (idNorm === 'da') {
      opcoes.add('diretorio academico');
      opcoes.add('diretorio');
    }

    opcoes.forEach((alias) => {
      adicionarAlias(alias, id, 2);
    });

    const salas = Array.isArray(locaisCache[id]?.salas) ? locaisCache[id].salas : [];
    salas.forEach((sala) => {
      const textoSala = String(sala || '');
      textoSala.split(/[,;]+/).forEach((parte) => {
        parte
          .split(':')
          .map((p) => p.trim())
          .filter(Boolean)
          .forEach((segmento) => {
            const alias = normalizarTexto(segmento);
            adicionarAlias(alias, id, 3);
          });
      });
    });
  });

  const aliases = [];
  aliasMap.forEach((ids, alias) => {
    if (ids.size === 1) {
      aliases.push({ alias, id: Array.from(ids)[0] });
    }
  });

  aliases.sort((a, b) => b.alias.length - a.alias.length);
  return aliases;
}

function extrairLocaisMencionados(texto) {
  const textoNorm = normalizarTexto(texto);
  if (!textoNorm) return [];

  const encontrados = [];
  const jaAdicionados = new Set();

  aliasesLocais.forEach(({ alias, id }) => {
    const regex = new RegExp(`(^|\\s)${escaparRegExp(alias)}(?=\\s|$)`, 'g');
    let match;
    while ((match = regex.exec(textoNorm)) !== null) {
      encontrados.push({ id, idx: match.index + (match[1] ? match[1].length : 0) });
    }
  });

  encontrados.sort((a, b) => a.idx - b.idx);

  const idsOrdenados = [];
  encontrados.forEach(({ id }) => {
    if (jaAdicionados.has(id)) return;
    jaAdicionados.add(id);
    idsOrdenados.push(id);
  });

  return idsOrdenados;
}

function construirMapaPrefixosBloco() {
  const mapa = {};
  Object.keys(locaisCache).forEach((id) => {
    const nome = normalizarTexto(id);
    if (!nome.startsWith('bloco ')) return;

    const sufixo = nome.replace('bloco ', '').trim();
    const partes = sufixo.split('/').map((p) => p.trim()).filter(Boolean);
    partes.forEach((parte) => {
      const letra = (parte || '')[0];
      if (letra && /[a-z]/.test(letra)) {
        mapa[letra] = id;
      }
    });
  });
  return mapa;
}

function construirMapaLipParaLocal() {
  const mapa = {};
  Object.entries(locaisCache).forEach(([id, dados]) => {
    const salas = Array.isArray(dados?.salas) ? dados.salas : [];
    salas.forEach((sala) => {
      const match = String(sala || '').match(/\blip\s*-?\s*(\d{1,3})\b/i);
      if (!match) return;
      const numero = match[1].padStart(2, '0');
      mapa[numero] = id;
    });
  });
  return mapa;
}

function extrairLocaisPorSala(texto) {
  const textoNorm = normalizarTexto(texto);
  if (!textoNorm) return [];

  const mapaPrefixos = construirMapaPrefixosBloco();
  const mapaLip = construirMapaLipParaLocal();
  const encontrados = [];
  const regexBloco = /\bbloco\s+([a-z])\b/g;
  let matchBloco;

  while ((matchBloco = regexBloco.exec(textoNorm)) !== null) {
    const letra = (matchBloco[1] || '').toLowerCase();
    const localId = mapaPrefixos[letra];
    if (!localId) continue;
    encontrados.push({
      id: localId,
      idx: matchBloco.index,
      score: 3,
    });
  }
  const regexLip = /\blip\s*-?\s*(\d{1,3})\b/g;
  let matchLip;

  while ((matchLip = regexLip.exec(textoNorm)) !== null) {
    const numero = String(matchLip[1] || '').padStart(2, '0');
    const localId = mapaLip[numero];
    if (!localId) continue;
    encontrados.push({
      id: localId,
      idx: matchLip.index,
      score: 3,
    });
  }
  const regex = /\b([a-z]{1,4})\s*-?\s*(\d{1,3})\b/g;
  let match;

  while ((match = regex.exec(textoNorm)) !== null) {
    const prefixo = (match[1] || '').toLowerCase();
    const chave = prefixo[0];
    const localId = mapaPrefixos[chave];
    if (!localId) continue;

    encontrados.push({
      id: localId,
      idx: match.index,
      score: prefixo === chave ? 2 : 1,
    });
  }

  if (!encontrados.length) return [];

  encontrados.sort((a, b) => {
    if (a.idx !== b.idx) return a.idx - b.idx;
    return b.score - a.score;
  });

  const ordenados = [];
  const vistos = new Set();
  encontrados.forEach(({ id }) => {
    if (vistos.has(id)) return;
    vistos.add(id);
    ordenados.push(id);
  });

  return ordenados;
}

function extrairReferenciasOrdenadas(texto) {
  const locaisTexto = extrairLocaisMencionados(texto);
  const locaisSala = extrairLocaisPorSala(texto);

  const unificados = [];
  const vistos = new Set();
  for (const id of [...locaisTexto, ...locaisSala]) {
    if (vistos.has(id)) continue;
    vistos.add(id);
    unificados.push(id);
  }
  return unificados;
}

function interpretarComandoRota(pergunta) {
  const textoNorm = normalizarTexto(pergunta);
  const locais = extrairReferenciasOrdenadas(pergunta);
  if (!locais.length) return null;

  const temIndicadorOrigem = /(\b(estou|estava|tava|to|tô|estamos|saindo|partindo|vindo)\b)/.test(textoNorm);
  const temIndicadorDestino = /(\b(quero|queria|gostaria|preciso|vou|ir|indo|destino|ate|até|para|pra|pro)\b)/.test(textoNorm);

  if (locais.length >= 2 && (temIndicadorOrigem || temIndicadorDestino)) {
    return { origem: locais[0], destino: locais[locais.length - 1] };
  }

  if (temIndicadorOrigem) {
    return { origem: locais[0] };
  }

  return null;
}

