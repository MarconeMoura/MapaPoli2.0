function pontoDentroDoRaio(xPct, yPct, alvo, container) {
  const xPx = (xPct / 100) * container.width;
  const yPx = (yPct / 100) * container.height;
  const alvoXPx = (alvo.x / 100) * container.width;
  const alvoYPx = (alvo.y / 100) * container.height;
  const dx = xPx - alvoXPx;
  const dy = yPx - alvoYPx;
  return Math.hypot(dx, dy) <= alvo.raioPx;
}

