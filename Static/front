  apresentacaoTokenAtual = token;
  clearTimeout(apresentacaoTimeout);

  let indice = 0;
  const avancar = () => {
    if (token !== apresentacaoTokenAtual) return;
    setMascotPose(sequencia[indice]);
    indice += 1;
    if (indice >= sequencia.length) {
      apresentacaoTimeout = null;
      return;
    }
    apresentacaoTimeout = setTimeout(avancar, intervaloMs);
  };

  avancar();
}

