
<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Mapa Interativo POLI UPE</title>

<style>
@import url('https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;700;800&family=Nunito:wght@500;700;800&display=swap');

* {
box-sizing: border-box;
}

:root {
--ceu-top: #ff7eb6;
--ceu-bottom: #ffe8f3;
--painel: #c94887;
--painel-escuro: #9f2f69;
--texto-claro: #fff3fa;
--botao-borda: #f5a8cb;
--botao-cinza: #f1dce8;
--botao-cinza-borda: #c799b0;
--verde-top: #95e95b;
--verde-bottom: #279f39;
--verde-borda: #16702c;
/* Posicao vertical do glow/anel atras do avatar - DESKTOP */
--hero-glow-bottom-desktop: 110px;
--hero-ring-bottom-desktop: 110px;
/* Posicao vertical do glow/anel atras do avatar - MOBILE */
--hero-glow-bottom-mobile: 58px;
--hero-ring-bottom-mobile: 54px;
}

body {
margin: 0;
min-height: 100vh;
font-family: "Nunito", "Segoe UI", sans-serif;
background:
radial-gradient(circle at 15% 8%, rgba(255, 255, 255, 0.72) 0, rgba(255, 255, 255, 0) 28%),
radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.58) 0, rgba(255, 255, 255, 0) 24%),
linear-gradient(180deg, var(--ceu-top) 0%, var(--ceu-bottom) 64%);
display: flex;
justify-content: center;
color: #5b1b3f;
padding: 14px;
}

.game-shell {
width: min(920px, 100%);
min-height: calc(100vh - 28px);
border-radius: 26px;
background: linear-gradient(180deg, rgba(255, 209, 231, 0.72), rgba(247, 160, 200, 0.62));
border: 2px solid rgba(255, 255, 255, 0.68);
box-shadow: 0 18px 44px rgba(117, 25, 74, 0.35);
position: relative;
overflow: hidden;
display: flex;
flex-direction: column;
padding: 16px 16px 14px;
}

.topbar {
display: block;
align-items: center;
margin-bottom: 8px;
}

.audio-gate {
position: fixed;
inset: 0;
display: flex;
align-items: center;
justify-content: center;
background: rgba(255, 237, 246, 0.92);
backdrop-filter: blur(3px);
z-index: 999;
}

.audio-gate[aria-hidden="true"] {
display: none;
}

.audio-gate-card {
background: rgba(255, 255, 255, 0.95);
border: 2px solid #d98ab2;
border-radius: 16px;
padding: 16px 18px;
box-shadow: 0 14px 28px rgba(117, 25, 74, 0.28);
display: grid;
gap: 12px;
text-align: left;
width: min(520px, 92vw);
}

.audio-gate-card strong {
color: #8d235d;
font-family: "Baloo 2", sans-serif;
font-size: 1.1rem;
text-align: center;
}

.audio-gate-actions {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 10px;
}

.audio-gate button {
border: 2px solid #16702c;
background: linear-gradient(180deg, var(--verde-top), var(--verde-bottom));
color: #13361b;
font-family: "Baloo 2", sans-serif;
font-size: 1.05rem;
font-weight: 800;
padding: 12px 14px;
border-radius: 12px;
cursor: pointer;
box-shadow: 0 10px 20px rgba(14, 49, 82, 0.28);
}

.audio-gate button.secondary {
border-color: #c799b0;
background: linear-gradient(180deg, #f7e8f1, #e6cddc);
color: #5b1b3f;
}

.cadastro-step {
display: none;
gap: 10px;
}

.cadastro-step.is-active {
display: grid;
}

.cadastro-field {
display: grid;
gap: 6px;
}

.cadastro-field label {
font-weight: 700;
color: #6d2850;
}

.cadastro-field input,
.cadastro-field select {
height: 42px;
border-radius: 10px;
border: 2px solid #d7a6c0;
padding: 0 10px;
font-family: "Nunito", sans-serif;
font-size: 0.95rem;
outline: none;
}

.cadastro-field input:focus,
.cadastro-field select:focus {
border-color: #ffe58c;
box-shadow: 0 0 0 3px rgba(255, 229, 140, 0.26);
}

.cadastro-opcoes {
display: grid;
gap: 6px;
font-size: 0.9rem;
color: #6d2850;
}

.cadastro-opcoes label {
display: flex;
gap: 8px;
align-items: center;
}

.brand {
margin: 0;
text-align: center;
color: #8d235d;
font-size: clamp(2rem, 5vw, 3.4rem);
line-height: 1;
letter-spacing: 1px;
font-family: "Baloo 2", "Nunito", sans-serif;
font-weight: 800;
text-shadow: 0 2px 0 rgba(255, 255, 255, 0.8);
}

.map-stage {
position: relative;
flex: 0 0 auto;
min-height: 430px;
height: clamp(400px, 64vh, 620px);
border-radius: 22px;
border: 2px solid #d98ab2;
background: linear-gradient(180deg, #ffd6eb 0%, #ffeaf6 45%, #ffe3ef 100%);
overflow: hidden;
box-shadow: inset 0 0 0 4px rgba(255, 255, 255, 0.4), 0 10px 22px rgba(0, 0, 0, 0.2);
}

#game-container {
position: absolute;
inset: 0;
background: #ffeaf6;
}

#map-base {
position: absolute;
inset: 0;
width: 100%;
height: 100%;
object-fit: fill;
background: #ffeaf6;
z-index: 1;
pointer-events: none;
}

#trilhas-svg,
#rota-svg {
position: absolute;
inset: 0;
width: 100%;
height: 100%;
pointer-events: none;
}

#trilhas-svg {
z-index: 2;
}

#rota-svg {
z-index: 4;
}

.linha-trilha {
display: none;
}

#checkpoints-layer {
position: absolute;
inset: 0;
z-index: 6;
}

.checkpoint {
position: absolute;
width: 46px;
height: 46px;
transform: translate(-50%, -100%);
border-radius: 50% 50% 50% 0;
rotate: -45deg;
cursor: pointer;
background: radial-gradient(circle at 35% 35%, #eaf8ff, #93d9ff 62%, #5dbcf2);
border: 2px solid #2f8dc0;
box-shadow: 0 8px 18px rgba(0, 0, 0, 0.3);
transition: transform 0.14s ease;
display: flex;
align-items: center;
justify-content: center;
animation: checkpointFloat 1.8s ease-in-out infinite;
}

.checkpoint.is-target {
background: radial-gradient(circle at 35% 35%, #fff8d6, #ffd166 62%, #f4a261);
border-color: #c97c2c;
box-shadow: 0 0 0 6px rgba(255, 209, 102, 0.45), 0 12px 22px rgba(0, 0, 0, 0.3);
animation: checkpointPulse 1s ease-in-out infinite;
transform: translate(-50%, -102%) scale(1.12);
}

.checkpoint:hover {
transform: translate(-50%, -102%) scale(1.08);
}

.checkpoint span {
rotate: 45deg;
color: #0f4f70;
font-family: "Baloo 2", sans-serif;
font-size: 0.9rem;
font-weight: 800;
margin-top: 2px;
}

@keyframes checkpointFloat {
0%, 100% { margin-top: 0; }
50% { margin-top: -3px; }
}

@keyframes checkpointPulse {
0%, 100% { transform: translate(-50%, -102%) scale(1.08); }
50% { transform: translate(-50%, -104%) scale(1.18); }
}

#avatar-on-map {
position: absolute !important;
width: 74px;
height: 74px;
background-image: url('/static/idle1.png');
background-size: contain;
background-repeat: no-repeat;
background-position: center;
z-index: 8;
transform: translate3d(-50%, -50%, 0);
filter: drop-shadow(0 5px 10px rgba(0, 0, 0, 0.35));
transition: left 180ms linear, top 180ms linear;
will-change: left, top;
backface-visibility: hidden;
-webkit-backface-visibility: hidden;
}

#avatar-on-map.is-walking {
animation: avatarWalkBob 380ms ease-in-out infinite;
}

@keyframes avatarWalkBob {
0%, 100% { transform: translate3d(-50%, -50%, 0); }
50% { transform: translate3d(-50%, -54%, 0); }
}

.route-chip {
position: relative;
z-index: 1;
background: rgba(255, 250, 230, 0.9);
border: 1px solid rgba(89, 77, 16, 0.34);
box-shadow: 0 7px 14px rgba(0, 0, 0, 0.22);
border-radius: 14px;
padding: 6px 12px;
font-family: "Baloo 2", sans-serif;
font-size: 1.05rem;
font-weight: 700;
color: #3f3509;
text-align: center;
max-width: 100%;
}

#mascot-container {
display: grid;
grid-template-rows: auto auto auto;
gap: 10px;
align-items: stretch;
pointer-events: auto;
}

.cards-row-top {
display: grid;
grid-template-columns: 340px 1fr;
gap: 14px;
align-items: stretch;
}

.cards-row-mid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 14px;
align-items: stretch;
}

.mascot-card {
background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 235, 246, 0.94));
border: 2px solid #d98ab2;
border-radius: 16px;
min-height: 220px;
box-shadow: 0 10px 20px rgba(135, 34, 86, 0.22);
position: relative;
overflow: hidden;
display: flex;
align-items: center;
justify-content: center;
padding: 12px 8px;
}

.mascot-card::before {
content: "";
position: absolute;
width: 232px;
height: 232px;
left: 50%;
bottom: var(--hero-glow-bottom-desktop);
transform: translateX(-50%);
border-radius: 50%;
background: radial-gradient(circle, rgba(255, 244, 171, 0.95) 0%, rgba(255, 214, 86, 0.55) 40%, rgba(255, 201, 45, 0) 72%);
filter: blur(1px);
animation: heroGlow 2.8s ease-in-out infinite;
z-index: 0;
}

.mascot-card::after {
content: "";
position: absolute;
width: 254px;
height: 254px;
left: 50%;
bottom: var(--hero-ring-bottom-desktop);
transform: translateX(-50%);
border-radius: 50%;
border: 2px dashed rgba(201, 72, 135, 0.35);
animation: heroRing 8s linear infinite;
z-index: 0;
}

/* Tamanho do avatar - DESKTOP */
#polia-side-shell {
width: 380px;
height: 380px;
display: flex;
align-items: center;
justify-content: center;
z-index: 1;
}

#polia-side-mascot {
width: 368px;
height: 368px;
object-fit: contain;
filter: drop-shadow(0 8px 12px rgba(0, 0, 0, 0.25));
transition: transform 240ms cubic-bezier(0.22, 1, 0.36, 1);
animation: heroFloat 3s ease-in-out infinite;
}

@keyframes heroGlow {
0%, 100% { opacity: 0.78; transform: translateX(-50%) scale(1); }
50% { opacity: 1; transform: translateX(-50%) scale(1.06); }
}

@keyframes heroRing {
from { transform: translateX(-50%) rotate(0deg); }
to { transform: translateX(-50%) rotate(360deg); }
}

@keyframes heroFloat {
0%, 100% { margin-bottom: 0; }
50% { margin-bottom: 6px; }
}

.interactive-column {
display: grid;
grid-template-rows: auto auto;
gap: 8px;
pointer-events: auto;
}

.control-strip {
margin-top: 0;
margin-bottom: 10px;
display: grid;
gap: 10px;
}

#speech-bubble-mascot {
background: linear-gradient(160deg, #fffdf4, #ffffff);
border: 2px solid #d98ab2;
border-radius: 14px;
color: #6d2850;
font-size: 0.9rem;
font-weight: 700;
line-height: 1.34;
padding: 10px 12px;
box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
opacity: 0;
visibility: hidden;
transform: translateY(5px) scale(0.99);
transition: opacity 240ms ease, transform 280ms cubic-bezier(0.22, 1, 0.36, 1), visibility 0s linear 240ms;
}

#speech-bubble-mascot.is-visible {
opacity: 1;
visibility: visible;
transform: translateY(0) scale(1);
transition: opacity 240ms ease, transform 280ms cubic-bezier(0.22, 1, 0.36, 1), visibility 0s linear 0s;
}

#polia-foto-balao {
background: linear-gradient(160deg, #fffdf4, #ffffff);
border: 2px solid #d98ab2;
border-radius: 14px;
box-shadow: 0 8px 18px rgba(0, 0, 0, 0.2);
display: grid;
gap: 8px;
padding: 10px;
min-height: 220px;
}

.polia-foto-placeholder {
font-family: "Baloo 2", sans-serif;
font-size: 0.9rem;
font-weight: 700;
color: #6d2850;
opacity: 0.8;
line-height: 1.25;
display: grid;
place-items: center;
text-align: center;
padding: 10px 8px;
border-radius: 12px;
border: 2px dashed rgba(201, 72, 135, 0.35);
}

#polia-foto-balao .polia-foto-topo,
#polia-foto-balao #polia-foto-img {
display: none;
}

#polia-foto-balao.is-visible .polia-foto-placeholder {
display: none;
}

#polia-foto-balao.is-visible .polia-foto-topo {
display: flex;
}

#polia-foto-balao.is-visible #polia-foto-img {
display: block;
}

.polia-foto-topo {
display: flex;
align-items: center;
justify-content: space-between;
gap: 8px;
}

.polia-foto-caption {
font-family: "Baloo 2", sans-serif;
font-size: 0.86rem;
font-weight: 700;
color: #6d2850;
}

.polia-foto-fechar {
border: 0;
background: #f6d8e8;
color: #6d2850;
width: 28px;
height: 28px;
border-radius: 50%;
cursor: pointer;
font-weight: 800;
line-height: 1;
}

#polia-foto-img {
  width: 100%;
  height: 190px;
  object-fit: cover;
  border-radius: 10px;
  border: 2px solid #f0bfd7;
}

.hero-search-card {
background: var(--painel);
border: 2px solid #84c7ff;
border-radius: 14px;
padding: 10px;
color: var(--texto-claro);
box-shadow: 0 10px 16px rgba(14, 49, 82, 0.35);
}

.hero-search-card strong {
display: block;
margin-bottom: 8px;
font-size: 1rem;
line-height: 1.2;
}

.search-row {
display: grid;
grid-template-columns: 1fr auto;
gap: 8px;
}

.search-help {
margin-top: 8px;
font-size: 0.82rem;
line-height: 1.2;
opacity: 0.92;
}

.hero-search-card input {
min-width: 0;
height: 44px;
border-radius: 11px;
border: 2px solid #adcff1;
padding: 0 11px;
font-size: 0.95rem;
font-family: "Nunito", sans-serif;
outline: none;
}

.hero-search-card input:focus {
border-color: #ffe58c;
box-shadow: 0 0 0 3px rgba(255, 229, 140, 0.26);
}

.hero-search-card button {
height: 44px;
border-radius: 11px;
border: 2px solid var(--verde-borda);
background: linear-gradient(180deg, var(--verde-top), var(--verde-bottom));
color: #13361b;
padding: 0 14px;
font-size: 1.02rem;
font-family: "Baloo 2", sans-serif;
font-weight: 800;
cursor: pointer;
transition: transform 0.13s ease;
}

.hero-search-card button:hover {
transform: translateY(-1px) scale(1.01);
}

.details-strip {
margin-top: 10px;
background: rgba(255, 255, 255, 0.86);
border-radius: 13px;
border: 1px solid rgba(38, 92, 146, 0.35);
padding: 9px 11px;
display: grid;
gap: 4px;
box-shadow: 0 6px 12px rgba(20, 72, 114, 0.16);
}

#titulo-bloco {
margin: 0;
font-family: "Baloo 2", sans-serif;
color: #1d4f84;
font-size: 1.05rem;
}

#salas-bloco {
color: #285f93;
font-size: 0.9rem;
line-height: 1.3;
max-height: 88px;
overflow: auto;
}

@media (max-width: 820px) {
body { padding: 8px; }
.game-shell { min-height: calc(100vh - 16px); border-radius: 16px; padding: 10px; }
.topbar { margin-bottom: 6px; }
.map-stage { min-height: 420px; }
#mascot-container { grid-template-rows: auto auto auto; gap: 7px; }
.cards-row-top { grid-template-columns: 1fr; gap: 7px; }
.cards-row-mid { grid-template-columns: 1fr; gap: 7px; }
.mascot-card { min-height: 210px; }
#polia-side-shell { width: 290px; height: 290px; }
#polia-side-mascot { width: 276px; height: 276px; }
.mascot-card::before { width: 144px; height: 144px; bottom: var(--hero-glow-bottom-mobile); }
.mascot-card::after { width: 160px; height: 160px; bottom: var(--hero-ring-bottom-mobile); }
.hero-search-card strong { font-size: 0.94rem; }
.search-row { grid-template-columns: 1fr; }
}
</style>
</head>
<body>
<div id="cadastro-gate" class="audio-gate" aria-hidden="false">
<div class="audio-gate-card">
<strong>Cadastro rápido da Polia</strong>
<form id="cadastro-form">
<div id="cadastro-step-1" class="cadastro-step is-active">
<div class="cadastro-field">
<label>Você tem e-mail institucional?</label>
<div class="cadastro-opcoes">
<label><input type="radio" name="emailStatus" value="nao_quero" checked> Não quero informar ou não tenho</label>
<label><input type="radio" name="emailStatus" value="sim"> Sim, meu e-mail é:</label>
</div>
<input id="cadastro-email" type="email" placeholder="Ex: seu.nome@upe.br" disabled />
</div>
<div class="audio-gate-actions">
<button id="cadastro-avancar" type="button">Continuar</button>
</div>
</div>

<div id="cadastro-step-2" class="cadastro-step">
<div class="cadastro-field">
<label>Nome completo</label>
<input id="cadastro-nome" type="text" placeholder="Seu nome" />
</div>
<div class="cadastro-field">
<label>Curso</label>
<select id="cadastro-curso">
<option value="" selected>Selecione seu curso</option>
<optgroup label="Graduação">
<option value="Física de Materiais">Física de Materiais</option>
<option value="Engenharia Elétrica Eletrônica">Engenharia Elétrica Eletrônica</option>
<option value="Engenharia Elétrica Eletrotécnica">Engenharia Elétrica Eletrotécnica</option>
<option value="Engenharia Elétrica de Telecomunicações">Engenharia Elétrica de Telecomunicações</option>
<option value="Engenharia Civil">Engenharia Civil</option>
<option value="Engenharia Mecânica">Engenharia Mecânica</option>
<option value="Engenharia da Computação">Engenharia da Computação</option>
<option value="Engenharia de Controle e Automação">Engenharia de Controle e Automação</option>
</optgroup>
<optgroup label="Pós-graduação">
<option value="Engenharia de Segurança do Trabalho">Engenharia de Segurança do Trabalho</option>
<option value="Inteligência Artificial">Inteligência Artificial</option>
<option value="Ciência dos Dados e Analytics">Ciência dos Dados e Analytics</option>
<option value="Tecnologia e Gestão na Construção de Edificios">Tecnologia e Gestão na Construção de Edificios</option>
<option value="Inspeção, Manutenção e Recuperação de Estruturas">Inspeção, Manutenção e Recuperação de Estruturas</option>
<option value="Engenharia da Computação (Pós)">Engenharia da Computação (Pós)</option>
<option value="Engenharia de Sistemas">Engenharia de Sistemas</option>
<option value="Engenharia Civil (Pós)">Engenharia Civil (Pós)</option>
</optgroup>
<option value="nao_estudante">Não sou estudante</option>
</select>
</div>
<div class="cadastro-field" id="cadastro-funcao-field" style="display:none;">
<label>Se não for estudante, qual sua função?</label>
<input id="cadastro-funcao" type="text" placeholder="Ex: visitante, professor, técnico" />
</div>
<div class="audio-gate-actions">
<button id="cadastro-voltar" class="secondary" type="button">Voltar</button>
<button id="cadastro-iniciar" type="submit">Iniciar</button>
</div>
</div>
</form>
<div class="audio-gate-actions" style="margin-top: 6px;">
<button id="cadastro-limpar" class="secondary" type="button">Trocar cadastro</button>
</div>
</div>
</div>

<div class="game-shell">
<header class="topbar">
<h1 class="brand">UPE</h1>
</header>

<section class="control-strip">
<div id="mascot-container">
<div class="cards-row-top">
<div class="mascot-card">
<div id="polia-side-shell">
<img id="polia-side-mascot" src="/static/frames/frame_0001.png" alt="Mascote Polia" />
</div>
</div>

<div id="polia-foto-balao" aria-hidden="true">
<div id="polia-foto-placeholder" class="polia-foto-placeholder">A foto do destino vai aparecer aqui.</div>
<div class="polia-foto-topo">
<span id="polia-foto-caption" class="polia-foto-caption">Foto do bloco</span>
<button id="polia-foto-fechar" class="polia-foto-fechar" type="button" aria-label="Fechar foto">×</button>
</div>
<img id="polia-foto-img" src="" alt="Foto do bloco" loading="lazy" />
</div>
</div>

<div id="speech-bubble-mascot">Bem-vindo à POLI! Sou a Polia.</div>

<div class="cards-row-mid">
<div class="hero-search-card">
<strong>Buscar sala ou bloco</strong>
<div class="search-row">
<input type="text" id="input-pergunta" placeholder="Ex: K06, B01, Biblioteca" />
<button id="btn-buscar" type="button">BUSCAR</button>
</div>
<div class="search-help">Opcional: diga onde está. Ex.: estou no bloco H. O destino você escolhe clicando no mapa.</div>
</div>

<div class="details-strip">
<h2 id="titulo-bloco">INFO: ENTRADA</h2>
<div id="salas-bloco">Clique num bloco para ver as salas.</div>
</div>
</div>
</div>
</section>

<main class="map-stage">
<div id="game-container">
<img id="map-base" src="/static/mapa_poli_base.png" alt="Mapa do campus" />
<svg id="trilhas-svg"></svg>
<svg id="rota-svg">
  </svg>
<div id="checkpoints-layer"></div>
<div id="avatar-on-map" style="left: 32%; top: 80%;"></div>
</div>
</main>
</div>

<script>
const TEMPO_POR_TRECHO = 1400;
const INTERVALO_PASSOS = 420;
const ATIVAR_MOVIMENTO_CONTINUO = false;
const USAR_TTS_API = true;
const FORCAR_TTS_API = true;
const USAR_VOZ_PADRAO_DO_SISTEMA = true;
const VELOCIDADE_VOZ = 0.7; 
const PITCH_VOZ = 2.5; 
const VOZ_PREFERIDA = 'Luciana';
const VOZ_ALTERNATIVAS = ['Luciana', 'Fernanda', 'Joana', 'Google português do Brasil'];
const INTERVALO_IDLE_MIN = 900;
const INTERVALO_IDLE_MAX = 1900;
