async function moverPlayer(destino) {
  if (!locaisCache[destino]) return;
  mostrarFotoLocal(destino);
  
  // Limpa o alvo anterior e DESTACA O NOVO ALVO piscando em amarelo!
  limparCheckpointAlvo();
  destacarCheckpoint(destino);
  
  const meuTokenMovimento = ++movimentoTokenAtual;
  setMascotPose(FRAME_PENSAR);
  
  const rota = encontrarRota(localAtual, destino);
  if (!rota) return;

  try {
    const res = await fetch('/api/guiar', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ destino, contexto_extra: montarContextoPerfil() })
    });
    const data = await res.json();
    if (meuTokenMovimento !== movimentoTokenAtual) return;
    
    // Boneca começa a andar na rota
    await animarAvatarNaRota(rota, meuTokenMovimento);
    
    if (meuTokenMovimento !== movimentoTokenAtual) return;
    if (data.status === "sucesso") {
      localAtual = destino;
      tituloBloco.innerText = "INFO: " + formatarNomeLocal(destino).toUpperCase();
      salasBloco.innerHTML = data.salas ? "<strong>Salas:</strong><br>" + data.salas.join("<br>") : "";
      const framesResposta = data?.animacao?.boca?.sequencia || FRAMES_RESPOSTA;
      await aguardarFramesMascote(framesResposta, 16, 1800);
      configurarFalaAnimada(data.texto, POSE_ESPERA, {
        animacao: data.animacao,
        onEnd: () => mostrarFotoPendente(destino),
      });
    }
  } catch (e) { setMascotPose(POSE_ESPERA); }
}

async function perguntarVeterano() {
  const p = inputPergunta.value.trim(); if (!p) return;
  ocultarFotoLocal();
  inputPergunta.value = "";
  setMascotPose(FRAME_PENSAR);
  const declaracaoLocalizacao = ehDeclaracaoLocalizacao(p);

  const comandoRota = interpretarComandoRota(p);
  if (comandoRota?.origem && comandoRota?.destino) {
    const ok = definirLocalAtual(comandoRota.origem, true);
    if (ok) {
      await moverPlayer(comandoRota.destino);
      return;
    }
  }

  if (comandoRota?.origem) {
    const ok = definirLocalAtual(comandoRota.origem, true);
    if (ok) {
      const msg = `Perfeito! Agora vou considerar que você está em ${formatarNomeLocal(comandoRota.origem)}.`;
      configurarFalaAnimada(msg, POSE_ESPERA);
      return;
    }
  }

  try {
    const res = await fetch('/api/chat', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ pergunta: p, contexto_extra: montarContextoPerfil() })
    });
    const d = await res.json();
    if (d?.origem && d?.destino && locaisCache[d.origem] && locaisCache[d.destino]) {
      definirLocalAtual(d.origem, true);
      await moverPlayer(d.destino);
      return;
    }
    if (d?.origem && !d?.destino && locaisCache[d.origem]) {
      definirLocalAtual(d.origem, true);
      configurarFalaAnimada(d.texto || `Perfeito! Agora considero que você está em ${formatarNomeLocal(d.origem).toUpperCase()}.`, POSE_ESPERA, { animacao: d.animacao });
      return;
    }
    if (d?.destino && locaisCache[d.destino]) {
    if (declaracaoLocalizacao) {
    definirLocalAtual(d.destino, true);
    }
    await moverPlayer(d.destino);
    return;
    }
    configurarFalaAnimada(d.texto || "Não consegui pensar agora.", POSE_ESPERA, { animacao: d.animacao });
  } catch (e) { setMascotPose(POSE_ESPERA); }
}

