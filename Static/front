function framePathFromIndex(indiceZeroBaseado) {
  const indice = Math.max(0, Math.min(TOTAL_FRAMES - 1, indiceZeroBaseado));
  const numero = String(indice + 1).padStart(4, '0');
  return `frames/frame_${numero}.png`;
}

function montarSequenciaFrames(inicio, fim) {
  const inicioSeguro = Math.max(0, inicio);
  const fimSeguro = Math.min(TOTAL_FRAMES - 1, fim);
  if (fimSeguro < inicioSeguro) return [];
  return Array.from({ length: fimSeguro - inicioSeguro + 1 }, (_, idx) => framePathFromIndex(inicioSeguro + idx));
}

