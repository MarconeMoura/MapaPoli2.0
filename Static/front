if (cadastroForm) {
  cadastroForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const emailStatus = document.querySelector('input[name="emailStatus"]:checked')?.value || 'nao_quero';
    perfilUsuario = {
      emailStatus,
      email: emailStatus === 'sim' ? (emailInput?.value || '').trim() : '',
      nome: (nomeInput?.value || '').trim(),
      curso: cursoSelect?.value || '',
      funcao: funcaoInput?.value || '',
    };
    salvarPerfilCookie(perfilUsuario);
    introPendente = construirMensagemIntro();
    audioAtivado = true;
    if (cadastroGate) cadastroGate.setAttribute('aria-hidden', 'true');
    if (introPendente) {
      const texto = introPendente;
      introPendente = null;
      configurarFalaAnimada(texto, POSE_ESPERA, { apresentacao: true });
    }
  });
}

const perfilSalvo = carregarPerfilCookie();
if (perfilSalvo) {
  perfilUsuario = perfilSalvo;
  const emailStatus = perfilSalvo.emailStatus || 'nao_quero';
  const radio = document.querySelector(`input[name="emailStatus"][value="${emailStatus}"]`);
  if (radio) radio.checked = true;
  if (emailInput) {
    emailInput.value = perfilSalvo.email || '';
  }
  if (nomeInput) {
    nomeInput.value = perfilSalvo.nome || '';
  }
  if (cursoSelect && perfilSalvo.curso) {
    cursoSelect.value = perfilSalvo.curso;
  }
  if (funcaoInput) {
    funcaoInput.value = perfilSalvo.funcao || '';
  }
  if (step1) step1.classList.remove('is-active');
  if (step2) step2.classList.add('is-active');
  if (cadastroGate) cadastroGate.setAttribute('aria-hidden', 'false');
}

atualizarEmailInput();
atualizarFuncao();

carregarLocais();
</script>
</body>
</html>
